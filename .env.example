# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# BACKEND API (Server-only - REQUIRED)
# -----------------------------------------------------------------------------
# The backend API URL. This is server-only and never exposed to the browser.
# Must include the full path to the API version endpoint.
# Example: https://api.yourapp.com/api/v1
BACKEND_API_URL=

# -----------------------------------------------------------------------------
# APPLICATION URL (Optional)
# -----------------------------------------------------------------------------
# The public URL of your frontend application.
# Used for generating absolute URLs in emails, etc.
# NEXT_PUBLIC_APP_URL=https://yourapp.com

# -----------------------------------------------------------------------------
# AUTHENTICATION COOKIES (Reference)
# -----------------------------------------------------------------------------
# These are the cookie names used for authentication.
# They are set by the server and are HttpOnly (not accessible via JavaScript).
# Do NOT change these unless you also update the backend.
#
# auth_access_token   - JWT access token
# auth_refresh_token  - JWT refresh token  
# auth_expires_at     - Token expiration timestamp

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# - Variables starting with NEXT_PUBLIC_ are exposed to the browser
# - All other variables are server-only
# - BACKEND_API_URL must NEVER start with NEXT_PUBLIC_
