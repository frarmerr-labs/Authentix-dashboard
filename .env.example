# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (added automatically by Supabase Vercel integration in production)
# -----------------------------------------------------------------------------
# Public URL and anon key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — server-only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# -----------------------------------------------------------------------------
# BACKEND API
# -----------------------------------------------------------------------------
# Controls which backend environment the frontend talks to.
# Set to: local | test | prod
BACKEND_ENV=local

# Local backend (npm run dev in Authentix-backend)
BACKEND_URL_LOCAL=http://localhost:3001/api/v1

# Staging / test deployment
BACKEND_URL_TEST=https://authentix-backend-test.vercel.app/api/v1

# Production deployment
BACKEND_URL_PROD=https://authentix-backend.vercel.app/api/v1

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# - Variables starting with NEXT_PUBLIC_ are exposed to the browser bundle
# - All other variables are server-only (Next.js API routes / Server Components)
# - SUPABASE_SERVICE_ROLE_KEY must NEVER start with NEXT_PUBLIC_
# - On Vercel, the Supabase integration auto-populates the NEXT_PUBLIC_ vars
#   for the frontend. Add SUPABASE_URL + SUPABASE_SECRET_KEY manually in the
#   backend Vercel project (they use different names from what Supabase injects).
