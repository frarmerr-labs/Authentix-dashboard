# =============================================================================
# AUTHENTIX DASHBOARD — ENVIRONMENT VARIABLES
# =============================================================================
# Copy to .env.local for local dev. NEVER commit .env.local.
# In production (Vercel) set these in the Vercel dashboard → Settings → Env Vars.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE
# Supabase Vercel integration auto-populates these in production.
# For local dev, copy values from Supabase dashboard → Settings → API.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# -----------------------------------------------------------------------------
# BACKEND API URL
# Points the Next.js proxy to the Authentix backend.
#
# Local dev (backend running locally):
#   BACKEND_URL=http://localhost:3001/api/v1
#
# Local dev (no local backend — proxy to Railway staging):
#   BACKEND_URL=https://<staging-service>.up.railway.app/api/v1
#
# Vercel production deployment:
#   BACKEND_URL=https://api.authentix.xencus.com/api/v1
#
# Vercel staging deployment:
#   BACKEND_URL=https://<staging-api-service>.up.railway.app/api/v1
# -----------------------------------------------------------------------------
BACKEND_URL=http://localhost:3001/api/v1

# -----------------------------------------------------------------------------
# NEXT.JS
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here
